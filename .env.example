# Unison brain API token — get one at https://brain.unisonlabs.ai or via:
#   curl -X POST https://brain.unisonlabs.ai/v1/auth/provision \
#     -H 'Content-Type: application/json' \
#     -d '{"email":"you@example.com"}'
UNISON_TOKEN=usk_live_...

# Unison brain base URL — override for self-hosted deployments (optional)
UNISON_API_URL=https://brain.unisonlabs.ai
